APP_NAME=My Assist
LOG_LEVEL=INFO
DEFAULT_TRANSPORT=discord

DISCORD_TOKEN=
DISCORD_COMMAND_PREFIX=!
TELEGRAM_TOKEN=

OLLAMA_BASE_URL=http://127.0.0.1:11434
TEXT_MODEL=qwen3:8b
VISION_MODEL=qwen2.5vl:7b
REQUEST_TIMEOUT_SECONDS=120
MODEL_TEMPERATURE=0.3
MAX_CONTEXT_MESSAGES=12

WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

WEB_REGION=wt-wt
WEB_RESULTS_LIMIT=5

TRAVELPAYOUTS_TOKEN=

GOOGLE_CREDENTIALS_FILE=tokens/google_credentials.json
GOOGLE_TOKEN_FILE=tokens/google_token.json

ENABLE_LOCAL_COMMANDS=false
